{
  "info": {
    "name": "Cetakin API",
    "description": "REST API for Cetakin — an on-demand print and stationery ordering platform.\n\nThis collection runs as a complete hands-free workflow. Hit Send top to bottom — IDs and tokens are extracted and saved automatically.\n\n**Variables auto-managed:**\n- `token` — saved on every Login/Register\n- `shop_id` — saved after Register Partner\n- `atk_product_id` — saved after Add ATK Product\n- `print_order_id` — saved after Place Print Order\n- `atk_order_id` — saved after Place ATK Order",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "shop_id", "value": "", "type": "string" },
    { "key": "atk_product_id", "value": "", "type": "string" },
    { "key": "print_order_id", "value": "", "type": "string" },
    { "key": "atk_order_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Step 1 — Health Check",
      "description": "Verify the API and database are up before anything else.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Public endpoint. Returns 200 if API and DB are up, 503 if DB is unreachable."
          }
        }
      ]
    },
    {
      "name": "Step 2 — Admin Approves a Partner",
      "description": "Admin logs in, a partner registers, admin reviews and approves them.",
      "item": [
        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@printapp.com\",\n  \"password\": \"admin123\"\n}"
            },
            "description": "Token is automatically saved."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    console.log('Admin token saved.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register a Partner",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register/partner",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Partner\",\n  \"email\": \"jane@printshop.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"phone\": \"08123456789\",\n  \"shop_name\": \"Jane Print Shop\",\n  \"shop_address\": \"Jl. Contoh No. 1, Jakarta\",\n  \"shop_phone\": \"08123456789\",\n  \"shop_description\": \"Melayani cetak dokumen dan ATK\",\n  \"open_time\": \"08:00\",\n  \"close_time\": \"21:00\",\n  \"operating_days\": [\"Monday\", \"Tuesday\", \"Wednesday\", \"Thursday\", \"Friday\"],\n  \"latitude\": -6.2088,\n  \"longitude\": 106.8456\n}"
            },
            "description": "shop_id is automatically extracted and saved."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const shop = res.data && res.data.user && res.data.user.shop;",
                  "if (shop && shop.id) {",
                  "    pm.collectionVariables.set('shop_id', shop.id);",
                  "    console.log('shop_id saved:', shop.id);",
                  "} else {",
                  "    console.warn('Could not extract shop_id from response.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Pending Partners",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/partners?status=pending",
              "host": ["{{base_url}}"],
              "path": ["admin", "partners"],
              "query": [
                { "key": "status", "value": "pending", "description": "Filter: pending | approved | rejected" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "description": "Admin reviews pending registrations. shop_id is saved from the first result as a fallback."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (pm.collectionVariables.get('shop_id')) return;",
                  "const items = res.data && (res.data.items || res.data.data || res.data);",
                  "if (Array.isArray(items) && items[0] && items[0].shop) {",
                  "    pm.collectionVariables.set('shop_id', items[0].shop.id);",
                  "    console.log('shop_id saved from list:', items[0].shop.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Approve Partner",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/admin/partners/{{shop_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["admin", "partners", "{{shop_id}}", "approve"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "description": "Uses {{shop_id}} saved from Register a Partner."
          }
        },
        {
          "name": "Reject Partner (alternative)",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/admin/partners/{{shop_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["admin", "partners", "{{shop_id}}", "reject"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Incomplete registration documents.\"\n}"
            },
            "description": "Skip this if you already approved above."
          }
        }
      ]
    },
    {
      "name": "Step 3 — Partner Sets Up Shop",
      "description": "The approved partner logs in and configures their shop: services, pricing, and ATK catalog.",
      "item": [
        {
          "name": "Login as Partner",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@printshop.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Token is automatically saved, replacing the admin token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    console.log('Partner token saved.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "View My Shop",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/shops/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Update Services",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/shops/me/services",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"services\": [\"print\", \"photocopy\", \"binding\"],\n  \"operating_hours\": \"08:00 - 21:00\",\n  \"operating_days\": [\"Monday\", \"Tuesday\", \"Wednesday\", \"Thursday\", \"Friday\"]\n}"
            }
          }
        },
        {
          "name": "Update Pricing",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/shops/me/pricing",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bw_price\": 500,\n  \"color_price\": 1500,\n  \"binding_prices\": [5000, 10000, 15000]\n}"
            }
          }
        },
        {
          "name": "Add ATK Product",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/shops/me/atk",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pulpen Pilot G2\",\n  \"description\": \"Pulpen gel hitam 0.5mm\",\n  \"price\": 8000,\n  \"stock\": 100,\n  \"is_available\": true\n}"
            },
            "description": "atk_product_id is automatically extracted and saved."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const id = res.data && res.data.id;",
                  "if (id) {",
                  "    pm.collectionVariables.set('atk_product_id', id);",
                  "    console.log('atk_product_id saved:', id);",
                  "} else {",
                  "    console.warn('Could not extract atk_product_id from response.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "View My ATK Catalog",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/shops/me/atk",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
    },
    {
      "name": "Step 4 — Customer Discovers & Orders",
      "description": "Customer registers, discovers the shop, and places both a print order and an ATK order.",
      "item": [
        {
          "name": "Register as Customer",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Budi Customer\",\n  \"email\": \"budi@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"phone\": \"08198765432\"\n}"
            },
            "description": "Token is automatically saved after registration."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    console.log('Customer token saved.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Discover Nearby Shops",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/shops?lat=-6.2088&lng=106.8456&radius=10&min_rating=0",
              "host": ["{{base_url}}"],
              "path": ["shops"],
              "query": [
                { "key": "lat", "value": "-6.2088" },
                { "key": "lng", "value": "106.8456" },
                { "key": "radius", "value": "10" },
                { "key": "min_rating", "value": "0" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "description": "shop_id is confirmed from the first result (already set from registration step)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (pm.collectionVariables.get('shop_id')) {",
                  "    console.log('shop_id already set:', pm.collectionVariables.get('shop_id'));",
                  "    return;",
                  "}",
                  "const items = res.data && (res.data.items || res.data.data || res.data);",
                  "if (Array.isArray(items) && items[0]) {",
                  "    pm.collectionVariables.set('shop_id', items[0].id);",
                  "    console.log('shop_id saved from discovery:', items[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "View Shop Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/shops/{{shop_id}}",
              "host": ["{{base_url}}"],
              "path": ["shops", "{{shop_id}}"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Browse Shop ATK Catalog",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/shops/{{shop_id}}/atk",
              "host": ["{{base_url}}"],
              "path": ["shops", "{{shop_id}}", "atk"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Place Print Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders/print",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "shop_id", "value": "{{shop_id}}", "type": "text" },
                { "key": "file", "type": "file", "src": "", "description": "Attach a real PDF, max 10MB" },
                { "key": "total_pages", "value": "5", "type": "text" },
                { "key": "color_mode", "value": "bw", "type": "text" },
                { "key": "copies", "value": "1", "type": "text" },
                { "key": "binding", "value": "false", "type": "text" },
                { "key": "notes", "value": "Please print double-sided", "type": "text" }
              ]
            },
            "description": "print_order_id is automatically extracted and saved. Attach a real PDF to the file field."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const id = res.data && res.data.id;",
                  "if (id) {",
                  "    pm.collectionVariables.set('print_order_id', id);",
                  "    console.log('print_order_id saved:', id);",
                  "} else {",
                  "    console.warn('Could not extract print_order_id from response.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Place ATK Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders/atk",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shop_id\": \"{{shop_id}}\",\n  \"items\": [\n    { \"atk_id\": \"{{atk_product_id}}\", \"quantity\": 2 }\n  ],\n  \"notes\": \"Please wrap carefully\"\n}"
            },
            "description": "atk_order_id is automatically extracted and saved. Uses {{shop_id}} and {{atk_product_id}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const id = res.data && res.data.id;",
                  "if (id) {",
                  "    pm.collectionVariables.set('atk_order_id', id);",
                  "    console.log('atk_order_id saved:', id);",
                  "} else {",
                  "    console.warn('Could not extract atk_order_id from response.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "View My Print Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/orders/print",
              "host": ["{{base_url}}"],
              "path": ["orders", "print"],
              "query": [
                { "key": "status", "value": "pending", "disabled": true }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "View Print Order Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/orders/print/{{print_order_id}}",
              "host": ["{{base_url}}"],
              "path": ["orders", "print", "{{print_order_id}}"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "description": "Shows full order detail including status history timeline."
          }
        }
      ]
    },
    {
      "name": "Step 5 — Partner Processes Orders",
      "description": "Partner logs back in and advances order statuses through the pipeline.",
      "item": [
        {
          "name": "Login as Partner",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@printshop.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Token is automatically saved, replacing the customer token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    console.log('Partner token saved.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "View Incoming Print Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/partner/orders/print?status=pending",
              "host": ["{{base_url}}"],
              "path": ["partner", "orders", "print"],
              "query": [
                { "key": "status", "value": "pending" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Advance Print Order → confirmed",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/partner/orders/print/{{print_order_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["partner", "orders", "print", "{{print_order_id}}", "status"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}"
            }
          }
        },
        {
          "name": "Advance Print Order → processing",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/partner/orders/print/{{print_order_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["partner", "orders", "print", "{{print_order_id}}", "status"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"processing\"\n}"
            }
          }
        },
        {
          "name": "Advance Print Order → ready_for_pickup",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/partner/orders/print/{{print_order_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["partner", "orders", "print", "{{print_order_id}}", "status"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ready_for_pickup\"\n}"
            }
          }
        },
        {
          "name": "Advance Print Order → completed",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/partner/orders/print/{{print_order_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["partner", "orders", "print", "{{print_order_id}}", "status"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "description": "After this, the customer can submit a review."
          }
        },
        {
          "name": "View Incoming ATK Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/partner/orders/atk?status=pending",
              "host": ["{{base_url}}"],
              "path": ["partner", "orders", "atk"],
              "query": [
                { "key": "status", "value": "pending" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Advance ATK Order → confirmed",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/partner/orders/atk/{{atk_order_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["partner", "orders", "atk", "{{atk_order_id}}", "status"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}"
            }
          }
        },
        {
          "name": "Advance ATK Order → processing",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/partner/orders/atk/{{atk_order_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["partner", "orders", "atk", "{{atk_order_id}}", "status"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"processing\"\n}"
            }
          }
        },
        {
          "name": "Advance ATK Order → ready_for_pickup",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/partner/orders/atk/{{atk_order_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["partner", "orders", "atk", "{{atk_order_id}}", "status"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ready_for_pickup\"\n}"
            }
          }
        },
        {
          "name": "Advance ATK Order → completed",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/partner/orders/atk/{{atk_order_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["partner", "orders", "atk", "{{atk_order_id}}", "status"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "description": "After this, the customer can submit a review."
          }
        }
      ]
    },
    {
      "name": "Step 6 — Customer Reviews",
      "description": "Customer logs back in and submits reviews. Shop rating updates automatically via DB trigger.",
      "item": [
        {
          "name": "Login as Customer",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"budi@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Token is automatically saved, replacing the partner token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    console.log('Customer token saved.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Review Print Order",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/orders/print/{{print_order_id}}/review",
