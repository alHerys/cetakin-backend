            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Fast and good quality!\"\n}"
            },
            "description": "One review per order. Duplicates return 422."
          }
        },
        {
          "name": "Review ATK Order",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/orders/atk/{{atk_order_id}}/review",
