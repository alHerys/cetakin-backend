{
  "info": {
    "name": "Cetakin API",
    "description": "REST API for Cetakin — an on-demand print and stationery ordering platform.\n\n**Setup:**\n1. Set `base_url` variable to `http://localhost:8000/api/v1`\n2. Login with any account → copy the `token` from the response\n3. Set `token` variable — all protected requests use it automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Check API and database connectivity. No auth required."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Customer)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Customer\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register (Partner)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register/partner",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Partner\",\n  \"email\": \"jane@printshop.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"shop_name\": \"Jane Print Shop\",\n  \"shop_address\": \"Jl. Contoh No. 1, Jakarta\",\n  \"shop_latitude\": -6.2088,\n  \"shop_longitude\": 106.8456,\n  \"shop_phone\": \"08123456789\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@printapp.com\",\n  \"password\": \"admin123\"\n}"
            },
            "description": "Token is automatically extracted and saved to the `token` collection variable after a successful login."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    console.log('Token saved automatically.');",
                  "} else {",
                  "    console.warn('Login response did not contain a token. Check credentials.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Partners",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/partners?status=pending",
              "host": ["{{base_url}}"],
              "path": ["admin", "partners"],
              "query": [
                { "key": "status", "value": "pending", "description": "Filter: pending | approved | rejected" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Approve Partner",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/partners/:id/approve",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/partners/:id/approve",
              "host": ["{{base_url}}"],
              "path": ["admin", "partners", ":id", "approve"],
              "variable": [{ "key": "id", "value": "<shop_id>" }]
            }
          }
        },
        {
          "name": "Reject Partner",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/admin/partners/:id/reject",
              "host": ["{{base_url}}"],
              "path": ["admin", "partners", ":id", "reject"],
              "variable": [{ "key": "id", "value": "<shop_id>" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Incomplete registration documents.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Shop Discovery (Customer)",
      "item": [
        {
          "name": "Discover Nearby Shops",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/shops?lat=-6.2088&lng=106.8456&radius=5&min_rating=0",
              "host": ["{{base_url}}"],
              "path": ["shops"],
              "query": [
                { "key": "lat", "value": "-6.2088", "description": "Latitude" },
                { "key": "lng", "value": "106.8456", "description": "Longitude" },
                { "key": "radius", "value": "5", "description": "Radius in km" },
                { "key": "min_rating", "value": "0", "description": "Minimum average rating" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Get Shop Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/shops/:id",
              "host": ["{{base_url}}"],
              "path": ["shops", ":id"],
              "variable": [{ "key": "id", "value": "<shop_id>" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Get Shop ATK Catalog",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/shops/:id/atk",
              "host": ["{{base_url}}"],
              "path": ["shops", ":id", "atk"],
              "variable": [{ "key": "id", "value": "<shop_id>" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Get Shop Reviews",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/shops/:id/reviews",
              "host": ["{{base_url}}"],
              "path": ["shops", ":id", "reviews"],
              "variable": [{ "key": "id", "value": "<shop_id>" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
    },
    {
      "name": "Partner — Shop Management",
