    {
      "name": "Print Orders (Customer)",
      "item": [
        {
          "name": "Place Print Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders/print",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "shop_id", "value": "<shop_id>", "type": "text" },
                { "key": "file", "type": "file", "src": "", "description": "PDF file, max 10MB" },
                { "key": "total_pages", "value": "5", "type": "text" },
                { "key": "color_mode", "value": "bw", "type": "text", "description": "bw or color" },
                { "key": "copies", "value": "1", "type": "text" },
                { "key": "binding", "value": "false", "type": "text" },
                { "key": "notes", "value": "Please print double-sided", "type": "text" }
              ]
            },
            "description": "Multipart/form-data. Attach a real PDF to the `file` field."
          }
        },
        {
          "name": "List My Print Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/orders/print",
              "host": ["{{base_url}}"],
              "path": ["orders", "print"],
              "query": [
                { "key": "status", "value": "pending", "disabled": true, "description": "Filter: pending | confirmed | processing | ready_for_pickup | completed | cancelled" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Get Print Order Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/orders/print/:id",
              "host": ["{{base_url}}"],
              "path": ["orders", "print", ":id"],
              "variable": [{ "key": "id", "value": "<order_id>" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Cancel Print Order",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/orders/print/:id/cancel",
              "host": ["{{base_url}}"],
              "path": ["orders", "print", ":id", "cancel"],
              "variable": [{ "key": "id", "value": "<order_id>" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Submit Print Order Review",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/orders/print/:id/review",
              "host": ["{{base_url}}"],
              "path": ["orders", "print", ":id", "review"],
              "variable": [{ "key": "id", "value": "<order_id>" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Fast and good quality!\"\n}"
            },
            "description": "Order must be in `completed` status."
          }
        }
      ]
    },
    {
      "name": "Print Orders (Partner)",
      "item": [
