            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pulpen Pilot G2\",\n  \"description\": \"Pulpen gel hitam 0.5mm\",\n  \"price\": 9000,\n  \"stock\": 80,\n  \"is_available\": true\n}"
